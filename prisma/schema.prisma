generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  role      Role      @default(STUDENT)
  // Admin approval gate — new student registrations pending (false) tak login block.
  // Optional taake mojooda documents (admin/legacy users) read par error na dein.
  approved  Boolean?  @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  student   Student?
  sessions  Session[]
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model Student {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @unique @db.ObjectId
  rollNumber     String   @unique
  department     String
  batch          String
  gpa            Float?
  skills         String
  achievements   String
  profileImage   String?
  qrCode         String?
  isShinningStar Boolean  @default(false)
  starReason     String?
  bio            String?
  linkedIn       String?
  github         String?
  phone          String?
  cvData         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model Job {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  company      String
  location     String
  type         JobType
  description  String
  requirements String
  salary       String?
  deadline     DateTime?
  isActive     Boolean   @default(true)
  postedBy     String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Announcement {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  priority  Priority @default(NORMAL)
  createdAt DateTime @default(now())
}

model ShinningStar {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  photo      String?
  department String
  batch      String
  position   String?
  company    String?
  story      String?
  skills     String
  rollNumber String?
  gpa        Float?
  createdAt  DateTime @default(now())
}

model SliderImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  image     String?
  caption   String   @default("")
  subtitle  String   @default("")
  isVisible Boolean  @default(true)
  linkUrl   String   @default("")
  linkLabel String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model CareerTest {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId          String   @unique @db.ObjectId
  studentName        String
  rollNo             String
  trade              String
  institute          String
  year               String
  testDate           DateTime @default(now())
  sectionA           Json
  sectionB           Json
  scores             Json
  recommendedPathway String
  createdAt          DateTime @default(now())
}

model Lesson {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  title              String
  description        String?
  fileUrl            String
  fileType           String   // 'pdf' | 'ppt' | 'image' | 'video'
  fileName           String
  cloudinaryPublicId String
  uploadedBy         String   @db.ObjectId
  createdAt          DateTime @default(now())
}

// Trade/Course — image-only card (admin Canva mein title+details image mein bake karta hai)
model Trade {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl           String
  cloudinaryPublicId String   @default("")
  alt                String?  // optional — admin ke liye identify karne ka naam / accessibility
  order              Int      @default(0)
  createdAt          DateTime @default(now())
}

enum Role {
  STUDENT
  ADMIN
  PLACEMENT_OFFICER
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}
